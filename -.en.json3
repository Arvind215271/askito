  }, {
    "tStartMs": 570017,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "Oh!"
    } ]
  }, {
    "tStartMs": 571083,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Oh, my God, throw it over.\nOkay, what if we just throw it to purple?"
