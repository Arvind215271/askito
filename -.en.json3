  }, {
    "tStartMs": 618921,
    "dDurationMs": 1446,
    "segs": [ {
      "utf8": "or go team up on somebody."
    } ]
  }, {
    "tStartMs": 620400,
    "dDurationMs": 2617,
    "segs": [ {
      "utf8": "Yo, purple. Yo, BTMC. Yes or no?"
