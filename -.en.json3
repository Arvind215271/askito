  }, {
    "tStartMs": 531217,
    "dDurationMs": 1633,
    "segs": [ {
      "utf8": "Everyone has decided their teams."
    } ]
  }, {
    "tStartMs": 532883,
    "dDurationMs": 4767,
    "segs": [ {
      "utf8": "Two people chose yellow, two people\nchose blue, and one person chose pink."
