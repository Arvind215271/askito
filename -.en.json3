  }, {
    "tStartMs": 641717,
    "dDurationMs": 4750,
    "segs": [ {
      "utf8": "Oh, my gosh. Yellow has the most bombs\nin their circle now, this is insane."
    } ]
  }, {
    "tStartMs": 646617,
    "dDurationMs": 4516,
    "segs": [ {
      "utf8": "Yellow! We gotta get them out of ours.\nWe have so many. No!"
    } ]
  }, {
    "tStartMs": 651167,
    "dDurationMs": 2150,
    "segs": [ {
      "utf8": "Whoa. We're two and a half minutes in."
    } ]
  }, {
    "tStartMs": 653350,
    "dDurationMs": 3183,
    "segs": [ {
      "utf8": "You have seven minutes to get rid of\nall these bombs, or you guys are dead."
    } ]
  }, {
    "tStartMs": 656567,
    "dDurationMs": 2300,
    "segs": [ {
      "utf8": "I'm too lazy to run over there, man.\nI don't know."
    } ]
  }, {
    "tStartMs": 658900,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "Too lazy? It's for $50,000."
    } ]
  }, {
    "tStartMs": 661633,
    "dDurationMs": 2417,
    "segs": [ {
      "utf8": "As of right now,\nyellow is goin' home!"
    } ]
  }, {
    "tStartMs": 664083,
    "dDurationMs": 2684,
    "segs": [ {
      "utf8": "Listen, listen.\nI'm down to do the white."
    } ]
  }, {
    "tStartMs": 666800,
    "dDurationMs": 2300,
    "segs": [ {
      "utf8": "If you all want to move on,\nwe can do it."
    } ]
  }, {
    "tStartMs": 669150,
    "dDurationMs": 2883,
    "segs": [ {
      "utf8": "- Okay.\n- Throw every bomb in white, please!"
    } ]
  }, {
    "tStartMs": 672067,
    "dDurationMs": 1783,
    "segs": [ {
      "utf8": "Yellow, I'm coming to\nhelp you guys out!"
    } ]
  }, {
    "tStartMs": 673883,
    "dDurationMs": 867,
    "segs": [ {
      "utf8": "Yellow!"
    } ]
  }, {
    "tStartMs": 675233,
    "dDurationMs": 1767,
    "segs": [ {
      "utf8": "Let's take 'em all out.\nLet's take 'em all out."
    } ]
  }, {
    "tStartMs": 677033,
    "dDurationMs": 1484,
    "segs": [ {
      "utf8": "Get 'em in the white.\nGet 'em in the white!"
    } ]
  }, {
    "tStartMs": 679217,
    "dDurationMs": 1100,
    "segs": [ {
      "utf8": "This looks very free."
    } ]
  }, {
    "tStartMs": 680817,
    "dDurationMs": 1550,
    "segs": [ {
      "utf8": "Kalazar, I thought we were friends!"
    } ]
  }, {
    "tStartMs": 682400,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Why'd you switch up?"
    } ]
  }, {
    "tStartMs": 683433,
    "dDurationMs": 2267,
    "segs": [ {
      "utf8": "He went into yellow's thing and\nhe started throwing them out."
    } ]
  }, {
    "tStartMs": 685733,
    "dDurationMs": 2667,
    "segs": [ {
      "utf8": "My best interest is\nin the blue team, baby!"
    } ]
  }, {
    "tStartMs": 688850,
    "dDurationMs": 1667,
    "segs": [ {
      "utf8": "Yellow, I've never betrayed y'all!"
    } ]
  }, {
    "tStartMs": 690550,
    "dDurationMs": 2433,
    "segs": [ {
      "utf8": "I've never betrayed y'all!\nWe're all trying to do this together!"
    } ]
  }, {
    "tStartMs": 693017,
    "dDurationMs": 2333,
    "segs": [ {
      "utf8": "You had such a good thing\ngoing for you."
    } ]
  }, {
    "tStartMs": 695383,
    "dDurationMs": 2900,
    "segs": [ {
      "utf8": "Dude, you could've had a guaranteed\nonly three people left."
    } ]
  }, {
    "tStartMs": 698317,
    "dDurationMs": 3183,
    "segs": [ {
      "utf8": "Oh, my God, I cannot believe\nwe cleared that pit. We had like forty."
    } ]
  }, {
    "tStartMs": 701533,
    "dDurationMs": 4450,
    "segs": [ {
      "utf8": "Yellow team literally has zero,\nand pink says 70 with two minutes left."
    } ]
  }, {
    "tStartMs": 706017,
    "dDurationMs": 3783,
    "segs": [ {
      "utf8": "Puttin' the bombs in the area\nthat matches them the best, I would say."
    } ]
  }, {
    "tStartMs": 709833,
    "dDurationMs": 2650,
    "segs": [ {
      "utf8": "I think this contrast\nis really the most attractive."
    } ]
  }, {
    "tStartMs": 712817,
    "dDurationMs": 1716,
    "segs": [ {
      "utf8": "100! Triple digits!"
    } ]
  }, {
    "tStartMs": 714567,
    "dDurationMs": 2583,
    "segs": [ {
      "utf8": "In the last 14 seconds,\npink, take the floor."
    } ]
  }, {
    "tStartMs": 717183,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "Why did you decide to\nturn on your partners, blue?"
    } ]
  }, {
    "tStartMs": 720417,
    "dDurationMs": 1366,
    "segs": [ {
      "utf8": "I wanted all of us to win."
    } ]
  }, {
    "tStartMs": 721817,
    "dDurationMs": 3033,
    "segs": [ {
      "utf8": "I thought if we threw everything into\nthe white, we could all move on."
    } ]
  }, {
    "tStartMs": 724883,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "But it seems like I was wrong."
    } ]
  }, {
    "tStartMs": 726117,
    "dDurationMs": 2383,
    "segs": [ {
      "utf8": "You're now going home with nothing.\nBlow him up."
    } ]
  }, {
    "tStartMs": 728533,
    "dDurationMs": 1584,
    "segs": [ {
      "utf8": "Goodbye, everyone!"
    } ]
  }, {
    "tStartMs": 730150,
    "dDurationMs": 1133,
    "segs": [ {
      "utf8": "Oh, there he goes."
    } ]
  }, {
    "tStartMs": 731467,
    "dDurationMs": 2016,
    "segs": [ {
      "utf8": "I'm sorry, I'm sorry!"
    } ]
  }, {
    "tStartMs": 733700,
    "dDurationMs": 3283,
    "segs": [ {
      "utf8": "Let's move on to what could be\nthe most important decision"
    } ]
  }, {
    "tStartMs": 737017,
    "dDurationMs": 2083,
    "segs": [ {
      "utf8": "of these four remaining\ncontestants' lives."
    } ]
  }, {
    "tStartMs": 742683,
    "dDurationMs": 2517,
    "segs": [ {
      "utf8": "$12,500."
    } ]
  }, {
    "tStartMs": 745233,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "That's what you could all walk away with\nif you decide to end it now."
    } ]
  }, {
    "tStartMs": 748667,
    "dDurationMs": 1850,
    "segs": [ {
      "utf8": "Server, start the vote!"
    } ]
  }, {
    "tStartMs": 750717,
    "dDurationMs": 1533,
    "segs": [ {
      "utf8": "Aw, dude."
    } ]
  }, {
    "tStartMs": 752567,
    "dDurationMs": 2183,
    "segs": [ {
      "utf8": "Now we actually have to think about this."
    } ]
  }, {
    "tStartMs": 754783,
    "dDurationMs": 2500,
    "segs": [ {
      "utf8": "This is going to be a TNT maze, bro."
    } ]
  }, {
    "tStartMs": 757317,
    "dDurationMs": 3166,
    "segs": [ {
      "utf8": "Willis if you're willing to be transparent\nhow bad do you need this money?"
    } ]
  }, {
    "tStartMs": 760517,
    "dDurationMs": 3533,
    "segs": [ {
      "utf8": "I live with my grandpa. This money\nwill literally allow me to just go."
    } ]
  }, {
    "tStartMs": 764083,
    "dDurationMs": 2567,
    "segs": [ {
      "utf8": "Like, it's like, this is life or death\nfor me at this point."
    } ]
  }, {
    "tStartMs": 766683,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "I'm voting to leave. I'm with you, bro.\nIt's up to those two over there."
    } ]
  }, {
    "tStartMs": 770550,
    "dDurationMs": 2500,
    "segs": [ {
      "utf8": "Server… reveal the results."
    } ]
  }, {
    "tStartMs": 774567,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "Whoa!"
    } ]
  }, {
    "tStartMs": 775483,
    "dDurationMs": 1467,
    "segs": [ {
      "utf8": "No!"
    } ]
  }, {
    "tStartMs": 776983,
    "dDurationMs": 1284,
    "segs": [ {
      "utf8": "Willis, I did it for you!"
    } ]
  }, {
    "tStartMs": 778300,
    "dDurationMs": 2967,
    "segs": [ {
      "utf8": "I still appreciate you, bro.\nI still appreciate you."
    } ]
  }, {
    "tStartMs": 781333,
    "dDurationMs": 5200,
    "segs": [ {
      "utf8": "Half of you voted to stop, but half of you\nvoted to keep going, and that we will!"
    } ]
  }, {
    "tStartMs": 786567,
    "dDurationMs": 2633,
    "segs": [ {
      "utf8": "It's really simple. All you have to do\nis make it to the bunker"
    } ]
  }, {
    "tStartMs": 789233,
    "dDurationMs": 3334,
    "segs": [ {
      "utf8": "on the other side of\nthis massive TNT maze."
    } ]
  }, {
    "tStartMs": 792600,
    "dDurationMs": 3983,
    "segs": [ {
      "utf8": "Once a single player is safely inside,\na 60-second countdown will begin."
    } ]
  }, {
    "tStartMs": 796617,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "And when it reaches zero,\nthat bunker door will close,"
    } ]
  }, {
    "tStartMs": 799350,
    "dDurationMs": 3050,
    "segs": [ {
      "utf8": "and this entire TNT kingdom\nwill explode."
    } ]
  }, {
    "tStartMs": 802433,
    "dDurationMs": 1217,
    "segs": [ {
      "utf8": "Oh, my God, if we stick together,\nwe're good."
    } ]
  }, {
    "tStartMs": 803683,
    "dDurationMs": 1817,
    "segs": [ {
      "utf8": "Oh, come on, girl, I got this!"
    } ]
  }, {
    "tStartMs": 805533,
    "dDurationMs": 1167,
    "segs": [ {
      "utf8": "Hey, you found a flower."
    } ]
  }, {
    "tStartMs": 806733,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Throughout the map,\nyou'll see flowers."
    } ]
  }, {
    "tStartMs": 808767,
    "dDurationMs": 3283,
    "segs": [ {
      "utf8": "If you mine a flower,\nyou will win your mom a thousand dollars."
    } ]
  }, {
    "tStartMs": 812083,
    "dDurationMs": 2934,
    "segs": [ {
      "utf8": "Thanks to DoorDash,\nbecause they wanted to celebrate moms!"
    } ]
  }, {
    "tStartMs": 815050,
    "dDurationMs": 1233,
    "segs": [ {
      "utf8": "Guys, I love my mom."
    } ]
  }, {
    "tStartMs": 816317,
    "dDurationMs": 1866,
    "segs": [ {
      "utf8": "Dude, I need my mom to love me!"
    } ]
  }, {
    "tStartMs": 818217,
    "dDurationMs": 2750,
    "segs": [ {
      "utf8": "And while these contestants\nare busy giving back to their moms,"
    } ]
  }, {
    "tStartMs": 821000,
    "dDurationMs": 1867,
    "segs": [ {
      "utf8": "I'll tell you how you can easily\ndo the same,"
    } ]
  }, {
    "tStartMs": 822900,
    "dDurationMs": 3483,
    "segs": [ {
      "utf8": "by ordering your mom flowers\non DoorDash between now and Mother's Day."
    } ]
  }, {
    "tStartMs": 826750,
    "dDurationMs": 1017,
    "segs": [ {
      "utf8": "I have one,\nI have one!"
    } ]
  }, {
    "tStartMs": 827800,
    "dDurationMs": 1750,
    "segs": [ {
      "utf8": "I have two at the moment.\nI have two."
    } ]
  }, {
    "tStartMs": 829583,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "And to make this even more fun, if you use\ncode MrBeast between now and Mother's Day,"
    } ]
  }, {
    "tStartMs": 833817,
    "dDurationMs": 5200,
    "segs": [ {
      "utf8": "you'll be entered for a chance to win\n$1,000 from DoorDash to give to your mom."
    } ]
  }, {
    "tStartMs": 841067,
    "dDurationMs": 1283,
    "segs": [ {
      "utf8": "Wait, Willis,\nlet me get that one!"
    } ]
  }, {
    "tStartMs": 843517,
    "dDurationMs": 1216,
    "segs": [ {
      "utf8": "Yo, should we go?"
    } ]
  }, {
    "tStartMs": 844767,
    "dDurationMs": 1533,
    "segs": [ {
      "utf8": "Willis, I'm not trolling.\nWe have to do it."
    } ]
  }, {
    "tStartMs": 846333,
    "dDurationMs": 1067,
    "segs": [ {
      "utf8": "If we're going to do it,\nwe got to do it now."
    } ]
  }, {
    "tStartMs": 847433,
    "dDurationMs": 2767,
    "segs": [ {
      "utf8": "DoorDash is focused on\ngiving back to moms this year."
    } ]
  }, {
    "tStartMs": 850233,
    "dDurationMs": 4867,
    "segs": [ {
      "utf8": "Which is why they're also giving one\nrandom lucky person who uses code MrBeast"
    } ]
  }, {
    "tStartMs": 855133,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "an all expense paid trip to\nthe Bahamas for them and their mom."
    } ]
  }, {
    "tStartMs": 858567,
    "dDurationMs": 1850,
    "segs": [ {
      "utf8": "Wait a minute. Wait.\nHold up. Oh!"
    } ]
  }, {
    "tStartMs": 860450,
    "dDurationMs": 2300,
    "segs": [ {
      "utf8": "We're goin' in.\nWe're goin' in, Willis, we have to!"
    } ]
  }, {
    "tStartMs": 862783,
    "dDurationMs": 1900,
    "segs": [ {
      "utf8": "Just go.\nJust go, just go, just go, just go."
    } ]
  }, {
    "tStartMs": 864717,
    "dDurationMs": 1300,
    "segs": [ {
      "utf8": "They just went in the bunker!"
    } ]
  }, {
    "tStartMs": 866050,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Whoa, wait, the other two people\naren't anywhere near it."
    } ]
  }, {
    "tStartMs": 868683,
    "dDurationMs": 1034,
    "segs": [ {
      "utf8": "Are you serious!?"
    } ]
  }, {
    "tStartMs": 869750,
    "dDurationMs": 950,
    "segs": [ {
      "utf8": "Is this the bunker?"
    } ]
  }, {
    "tStartMs": 871417,
    "dDurationMs": 1750,
    "segs": [ {
      "utf8": "Wait, I went the wrong way!"
    } ]
  }, {
    "tStartMs": 873200,
    "dDurationMs": 2017,
    "segs": [ {
      "utf8": "Thank you, DoorDash,\nfor sponsoring this video."
    } ]
  }, {
    "tStartMs": 875250,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Guys, make sure\nyou download DoorDash,"
    } ]
  }, {
    "tStartMs": 877083,
    "dDurationMs": 1867,
    "segs": [ {
      "utf8": "order your mom some\nflowers for Mother's Day,"
    } ]
  }, {
    "tStartMs": 878983,
    "dDurationMs": 1517,
    "segs": [ {
      "utf8": "and show your mom that you care."
    } ]
  }, {
    "tStartMs": 880533,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Dude, the time's ticking.\nYou have to hurry!"
    } ]
  }, {
    "tStartMs": 883167,
    "dDurationMs": 1216,
    "segs": [ {
      "utf8": "I don't think I'm making this."
    } ]
  }, {
    "tStartMs": 884417,
    "dDurationMs": 1283,
    "segs": [ {
      "utf8": "Do you feel screwed over?"
    } ]
  }, {
    "tStartMs": 885733,
    "dDurationMs": 1567,
    "segs": [ {
      "utf8": "I feel so screwed over!"
    } ]
  }, {
    "tStartMs": 887333,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "I'm following the trail of empty flower\npots though hoping that gets me somewhere."
    } ]
  }, {
    "tStartMs": 891567,
    "dDurationMs": 1266,
    "segs": [ {
      "utf8": "Whoa, whoa. Go, go!"
    } ]
  }, {
    "tStartMs": 892867,
    "dDurationMs": 1283,
    "segs": [ {
      "utf8": "Go! Go!"
    } ]
  }, {
    "tStartMs": 894183,
    "dDurationMs": 1217,
    "segs": [ {
      "utf8": "Is this the bunker?"
    } ]
  }, {
    "tStartMs": 895433,
    "dDurationMs": 3617,
    "segs": [ {
      "utf8": "It's right there!\nRound the corner! Go, go!"
    } ]
  }, {
    "tStartMs": 899117,
    "dDurationMs": 1833,
    "segs": [ {
      "utf8": "Run for your moms!"
    } ]
  }, {
    "tStartMs": 901933,
    "dDurationMs": 1184,
    "segs": [ {
      "utf8": "Oh, no!"
    } ]
  }, {
    "tStartMs": 903150,
    "dDurationMs": 2917,
    "segs": [ {
      "utf8": "Oh, no, it's right there.\nWe were right there."
    } ]
  }, {
    "tStartMs": 906100,
    "dDurationMs": 1733,
    "segs": [ {
      "utf8": "The door is closing!"
    } ]
  }, {
    "tStartMs": 907867,
    "dDurationMs": 2983,
    "segs": [ {
      "utf8": "Oh, the door! No!"
    } ]
  }, {
    "tStartMs": 913300,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Oh, man!"
    } ]
  }, {
    "tStartMs": 916167,
    "dDurationMs": 2950,
    "segs": [ {
      "utf8": "Over here, you can see how many flowers\nthe dead people collected."
    } ]
  }, {
    "tStartMs": 919150,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "Wendy died,\nbut not before she got her mom $5,000."
    } ]
  }, {
    "tStartMs": 922783,
    "dDurationMs": 2317,
    "segs": [ {
      "utf8": "Kalazar's mom will receive $7,000."
    } ]
  }, {
    "tStartMs": 925133,
    "dDurationMs": 2567,
    "segs": [ {
      "utf8": "Good, good, good.\nThank God."
    } ]
  }, {
    "tStartMs": 927733,
    "dDurationMs": 1084,
    "segs": [ {
      "utf8": "Download DoorDash."
    } ]
  }, {
    "tStartMs": 928850,
    "dDurationMs": 3667,
    "segs": [ {
      "utf8": "The least you could do is use DoorDash and\nget her some flowers for Mother's Day."
    } ]
  }, {
    "tStartMs": 933117,
    "dDurationMs": 966,
    "segs": [ {
      "utf8": "Open the gate."
    } ]
  }, {
    "tStartMs": 935183,
    "dDurationMs": 2067,
    "segs": [ {
      "utf8": "Oh, my God!"
    } ]
  }, {
    "tStartMs": 937283,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "Dude."
    } ]
  }, {
    "tStartMs": 938167,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Right around this area\nwas your other two competitors."
    } ]
  }, {
    "tStartMs": 940800,
    "dDurationMs": 2967,
    "segs": [ {
      "utf8": "They saw the door slam shut in their face."
    } ]
  }, {
    "tStartMs": 946700,
    "dDurationMs": 3517,
    "segs": [ {
      "utf8": "Oh, my gosh, they're playing trumpets.\nNext round, next round, next round."
    } ]
  }, {
    "tStartMs": 953033,
    "dDurationMs": 3350,
    "segs": [ {
      "utf8": "Look at all the fallen comrades.\nOnly you two remain."
    } ]
  }, {
    "tStartMs": 956417,
    "dDurationMs": 3416,
    "segs": [ {
      "utf8": "Let's say you guys end it now,\nand Willis, you walked away with 30 grand."
    } ]
  }, {
    "tStartMs": 959867,
    "dDurationMs": 983,
    "segs": [ {
      "utf8": "What would you spend it on?"
    } ]
  }, {
    "tStartMs": 960883,
    "dDurationMs": 3384,
    "segs": [ {
      "utf8": "Dude, I've been working like\n14 to 15 hours every single day, man."
    } ]
  }, {
    "tStartMs": 964300,
    "dDurationMs": 3683,
    "segs": [ {
      "utf8": "You have no idea how bad I just needed\nsomething like this to happen in my life."
    } ]
  }, {
    "tStartMs": 968017,
    "dDurationMs": 2816,
    "segs": [ {
      "utf8": "I also have always been wanting to\nmove out."
    } ]
  }, {
    "tStartMs": 970867,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "And finally, this would put the cherry on\ntop for me to finally make that move in."
    } ]
  }, {
    "tStartMs": 974500,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "All right, this is life-changing for you."
    } ]
  }, {
    "tStartMs": 976483,
    "dDurationMs": 967,
    "segs": [ {
      "utf8": "It really is."
    } ]
  }, {
    "tStartMs": 977483,
    "dDurationMs": 4284,
    "segs": [ {
      "utf8": "Senny, before I ask\nwhat you're gonna spend the $30,000 on,"
    } ]
  }, {
    "tStartMs": 981800,
    "dDurationMs": 3417,
    "segs": [ {
      "utf8": "why do you have a picture of\nthe lady from Incredibles behind you?"
    } ]
  }, {
    "tStartMs": 985250,
    "dDurationMs": 967,
    "segs": [ {
      "utf8": "Let me show you an up-close."
    } ]
  }, {
    "tStartMs": 986250,
    "dDurationMs": 3250,
    "segs": [ {
      "utf8": "So when I get hungry during like\nstreams and stuff, I take a bite!"
    } ]
  }, {
    "tStartMs": 989533,
    "dDurationMs": 2434,
    "segs": [ {
      "utf8": "You're gonna split\nmoney with this guy, Willis?"
    } ]
  }, {
    "tStartMs": 992000,
    "dDurationMs": 2917,
    "segs": [ {
      "utf8": "If you win this 30 grand,\nis it going to more Invinci-Woman?"
    } ]
  }, {
    "tStartMs": 994950,
    "dDurationMs": 2717,
    "segs": [ {
      "utf8": "My actual answer?\nI'm gonna get my dad a safer car,"
    } ]
  }, {
    "tStartMs": 997700,
    "dDurationMs": 2817,
    "segs": [ {
      "utf8": "and I'm gonna invest into a clothing brand\nthat I've been working on."
    } ]
  }, {
    "tStartMs": 1000550,
    "dDurationMs": 3167,
    "segs": [ {
      "utf8": "So you guys both have some wholesome,\nlegitimate reasons for this money,"
    } ]
  }, {
    "tStartMs": 1003750,
    "dDurationMs": 1933,
    "segs": [ {
      "utf8": "then this next decision is very important."
    } ]
  }, {
    "tStartMs": 1005717,
    "dDurationMs": 5583,
    "segs": [ {
      "utf8": "You can either agree to split the $60,000\nor do one final challenge,"
    } ]
  }, {
    "tStartMs": 1011333,
    "dDurationMs": 3484,
    "segs": [ {
      "utf8": "the winner of which,\nI will wire $100,000."
    } ]
  }, {
    "tStartMs": 1014850,
    "dDurationMs": 1983,
    "segs": [ {
      "utf8": "Don't—you're doing this again!"
    } ]
  }, {
    "tStartMs": 1016867,
    "dDurationMs": 2383,
    "segs": [ {
      "utf8": "You're doing this thing\nwhere you're messing with our heads!"
    } ]
  }, {
    "tStartMs": 1019283,
    "dDurationMs": 2217,
    "segs": [ {
      "utf8": "Senny, please. I beg you, bro.\nLike I'm literally begging you."
    } ]
  }, {
    "tStartMs": 1021533,
    "dDurationMs": 1300,
    "segs": [ {
      "utf8": "Like, from the bottom of my heart.\nPlease."
    } ]
  }, {
    "tStartMs": 1022867,
    "dDurationMs": 2366,
    "segs": [ {
      "utf8": "I'm so serious. Willis, you have my word."
    } ]
  }, {
    "tStartMs": 1025267,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "But a $100,000…"
    } ]
  }, {
    "tStartMs": 1028500,
    "dDurationMs": 3533,
    "segs": [ {
      "utf8": "You're getting in my head!\nStop getting in my head! I'm not doin' it!"
    } ]
  }, {
    "tStartMs": 1032067,
    "dDurationMs": 2583,
    "segs": [ {
      "utf8": "Senny. I'm locked in.\nSenny, I'm locked in, bro."
    } ]
  }, {
    "tStartMs": 1034683,
    "dDurationMs": 1884,
    "segs": [ {
      "utf8": "I'm locked in, I'm locked in.\nI promise, I promise!"
    } ]
  }, {
    "tStartMs": 1036600,
    "dDurationMs": 2433,
    "segs": [ {
      "utf8": "Server, reveal the results!!"
    } ]
  }, {
    "tStartMs": 1042900,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "All right, it's over!\nYou both voted to end it."
    } ]
  }, {
    "tStartMs": 1045483,
    "dDurationMs": 2934,
    "segs": [ {
      "utf8": "And guys, if you're watching,\norder your mom some flowers on DoorDash"
    } ]
  }, {
    "tStartMs": 1048450,
    "dDurationMs": 1717,
    "segs": [ {
      "utf8": "and hit the Subscribe button.\nI'll see you later."
    } ]
  }, {
    "tStartMs": 1050200,
    "dDurationMs": 1617,
    "segs": [ {
      "utf8": "Let's blow this thing up anyway."
    } ]
  } ]
}
