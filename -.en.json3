  }, {
    "tStartMs": 7083,
    "dDurationMs": 2784,
    "segs": [ {
      "utf8": "some of the deadliest explosions\never made."
    } ]
  }, {
    "tStartMs": 9900,
    "dDurationMs": 3567,
    "segs": [ {
      "utf8": "Like this castle made out of\n50 million blocks of TNT,"
    } ]
  }, {
    "tStartMs": 13500,
    "dDurationMs": 2800,
    "segs": [ {
