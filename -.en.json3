  }, {
    "tStartMs": 593100,
    "dDurationMs": 2233,
    "segs": [ {
      "utf8": "Listen, it's me versus\nthe world right now, Karl."
    } ]
  }, {
    "tStartMs": 595367,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "If I can somehow clutch this up,\nI will literally go down in history."
