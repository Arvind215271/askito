  }, {
    "tStartMs": 526950,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "Yellow, yellow, yellow!"
    } ]
  }, {
    "tStartMs": 527817,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "- Hey, Willis!\n- I'm happy with you on my team, bro."
