  }, {
    "tStartMs": 608217,
    "dDurationMs": 2016,
    "segs": [ {
      "utf8": "This is a MrBeast video.\nI cannot feel guilty."
    } ]
  }, {
    "tStartMs": 612000,
    "dDurationMs": 2917,
    "segs": [ {
      "utf8": "Guys. Right now,\nthere's 58 bombs in the white space,"
