  }, {
    "tStartMs": 623050,
    "dDurationMs": 2017,
    "segs": [ {
      "utf8": "Oh, we got it! Oh, let's do it!\nLet's do it, let's do it!"
    } ]
  }, {
    "tStartMs": 625100,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "Everyone versus yellow.\nCome on, let's go, blue, let's go!"
    } ]
  }, {
    "tStartMs": 628433,
    "dDurationMs": 2484,
    "segs": [ {
      "utf8": "All right, I guess that's it.\nI guess that's it! That's the call!"
    } ]
  }, {
    "tStartMs": 630950,
    "dDurationMs": 1933,
    "segs": [ {
      "utf8": "Keep it up, keep it up, keep it up!\nGo go go go go!"
    } ]
  }, {
    "tStartMs": 632917,
    "dDurationMs": 1966,
    "segs": [ {
      "utf8": "Hey, whoa! Whoa! Whoa! Whoa!"
    } ]
  }, {
    "tStartMs": 634917,
    "dDurationMs": 3633,
    "segs": [ {
      "utf8": "Hey! Stop! Yellow!\nThrow them out, quick! They're teaming!"
