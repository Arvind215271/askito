  }, {
    "tStartMs": 566283,
    "dDurationMs": 900,
    "segs": [ {
      "utf8": "What?"
    } ]
  }, {
    "tStartMs": 567217,
    "dDurationMs": 900,
    "segs": [ {
      "utf8": "Start the game!"
