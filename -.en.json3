  }, {
    "tStartMs": 97467,
    "dDurationMs": 2016,
    "segs": [ {
      "utf8": "- Oh, gosh.\n- Oh, no."
    } ]
  }, {
    "tStartMs": 99517,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "Yo, guys, I'm fine with 20,000, bro!"
