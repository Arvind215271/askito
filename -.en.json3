  }, {
    "tStartMs": 568150,
    "dDurationMs": 1183,
    "segs": [ {
      "utf8": "Oh, you're joking!"
    } ]
  }, {
    "tStartMs": 569367,
    "dDurationMs": 616,
    "segs": [ {
      "utf8": "Uh-oh."
