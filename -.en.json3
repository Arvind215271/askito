  }, {
    "tStartMs": 537683,
    "dDurationMs": 2117,
    "segs": [ {
      "utf8": "That only makes it\nmore impressive if I win."
    } ]
  }, {
    "tStartMs": 539833,
    "dDurationMs": 3567,
    "segs": [ {
      "utf8": "Will everyone please direct\ntheir attention to the ten-minute timer?"
    } ]
  }, {
    "tStartMs": 543433,
    "dDurationMs": 4017,
    "segs": [ {
      "utf8": "When that timer starts, 100 bombs\nare gonna spawn all around the map."
    } ]
  }, {
    "tStartMs": 547483,
    "dDurationMs": 1450,
    "segs": [ {
      "utf8": "At the end of the ten-minute timer,"
