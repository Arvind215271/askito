APP_ENV=development
PORT=8080

# Optional: YouTube Data API key
# YOUTUBE_API_KEY=

# Optional: Override the default yt-dlp cache directory
YTDLP_CACHE_DIR=./.cache/ytdlp

# Optional: TTL for cached metadata in days
YTDLP_CACHE_TTL_DAYS=28

# Optional: Maximum number of files to keep in cache
YTDLP_CACHE_MAX_FILES=2000

# Number of Python workers used to process video metadata, playlists,
# and subtitles concurrently.
#
# Each worker uses approximately 50–60 MB of RAM and around 70 MB of VRAM.
# Increase this only if your system has enough available resources.
PYTHON_WORKERS=64