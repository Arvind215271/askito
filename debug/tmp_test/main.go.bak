package main

import (
	"bytes"
	"context"
	"fmt"
	"os/exec"
	"time"
)

func main() {
	videoID := "zp_S2Uwjb-M"
	ctx, cancel := context.WithTimeout(context.Background(), 60*time.Second)
	defer cancel()

	cmd := exec.CommandContext(ctx, "yt-dlp", "--skip-download", "--write-sub", "--sub-lang", "en", "--sub-format", "json3", "-o", "-", videoID)
	
	var stdout bytes.Buffer
	var stderr bytes.Buffer
	cmd.Stdout = &stdout
	cmd.Stderr = &stderr
	
	err := cmd.Run()
	if err != nil {
		fmt.Printf("Error running yt-dlp: %v\n", err)
	}
	
	fmt.Printf("Stderr: %s\n", stderr.String())
	fmt.Printf("Stdout length: %d\n", stdout.Len())
	if stdout.Len() > 0 {
		fmt.Printf("Output snippet: %s\n", stdout.String()[:min(100, stdout.Len())])
	}
}

func min(a, b int) int {
	if a < b {
		return a
	}
	return b
}
